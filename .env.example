APP_ENV=local
LOG_LEVEL=INFO

# LLM provider: mock or gemini
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Search policy
# no_search = real runtime with no external search
# mock = test-only fake provider
# tavily = paid/external provider
SEARCH_PROVIDER=no_search
PAID_SEARCH_PROVIDER=tavily
ALLOW_PAID_SEARCH=false
MAX_PAID_SEARCH_CALLS_PER_CASE=0

# Tavily
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=3
TAVILY_SEARCH_DEPTH=basic
